---
const year = new Date().getFullYear();
---

<footer
  id="contact"
  class="border-t border-slate-200/90 bg-slate-50 py-12 text-sm text-ink/75"
>
  <div class="page-shell flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
    <div class="max-w-xl space-y-3">
      <p class="text-xs font-bold font-label uppercase tracking-[0.2em] text-sea">
        Contact
      </p>
      <p class="text-balance text-base text-ink/85 lg:text-lg">
        Questions about nominations, applications, or ambassador events? Reach out to our
        program leads—responses typically come from your school Outlook thread.
      </p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:gap-10 lg:text-right">
      <div>
        <p class="text-xs uppercase tracking-wide text-ink/55">Assistant Administrator</p>
        <p class="font-semibold text-ink">Teri Schneider</p>
        <a
          class="mt-1 inline-block font-medium text-sea underline decoration-accent/50 underline-offset-2 hover:text-ink"
          href="mailto:tschneider@forsyth.k12.ga.us"
        >
          tschneider@forsyth.k12.ga.us
        </a>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wide text-ink/55">
          Induction Teacher Leader / Social Studies
        </p>
        <p class="font-semibold text-ink">Kerry Hartshorn</p>
        <a
          class="mt-1 inline-block font-medium text-sea underline decoration-accent/50 underline-offset-2 hover:text-ink"
          href="mailto:khartshorn@forsyth.k12.ga.us"
        >
          khartshorn@forsyth.k12.ga.us
        </a>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wide text-ink/55">Instagram</p>
        <a
          class="mt-1 inline-block font-semibold text-ink hover:text-sea"
          href="https://www.instagram.com/denmark_ap/"
          target="_blank"
          rel="noreferrer noopener"
        >
          @denmark_ap
        </a>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wide text-ink/55">Website manager/AP ambassador</p>
        <p class="font-semibold text-ink">Rohan Puppala</p>
        <a
          class="mt-1 inline-block font-medium text-sea underline decoration-accent/50 underline-offset-2 hover:text-ink"
          href="mailto:rohan.puppala36@gmail.com"
        >
          rohan.puppala36@gmail.com
        </a>
      </div>
    </div>
  </div>
  <div class="page-shell mt-10 border-t border-slate-200/90 pt-6 text-center text-xs uppercase tracking-[0.16em] text-ink/45">
    © {year} Denmark High School AP Ambassadors · Forsyth County Schools
  </div>
</footer>
