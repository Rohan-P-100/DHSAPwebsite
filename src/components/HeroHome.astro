---
const heroImage = "/images/new_hero.jpg";
---

<section
  id="top"
  class="relative scroll-mt-20 h-[calc(100svh-4rem)] overflow-hidden bg-white sm:scroll-mt-24 lg:h-[calc(100svh-4.25rem)]"
  aria-labelledby="hero-title"
>
  <div class="mx-auto flex h-full w-full max-w-[132rem] px-3 pb-4 pt-3 sm:px-6 sm:pb-8 sm:pt-5 lg:px-10 lg:pb-10">
    <div
      class="animate-fade-up relative w-full flex-1 overflow-hidden rounded-3xl border border-slate-200/90 bg-slate-100 opacity-0 shadow-[0_24px_60px_-12px_rgba(17,34,73,0.12)] ring-1 ring-slate-900/[0.04] lg:rounded-[2rem]"
      style="animation-delay: 0.12s;"
    >
      <img
        src={heroImage}
        alt="Denmark High School AP Ambassadors"
        class="h-full w-full object-cover object-[center_68%]"
        loading="eager"
        fetchpriority="high"
      />

      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/65 via-ink/20 to-transparent"
        aria-hidden="true"
      ></div>

      <div class="absolute inset-x-0 bottom-0 p-6 text-left sm:p-10 lg:p-14">
        <h1
          id="hero-title"
          class="w-full font-bold leading-[1.06] tracking-tight text-white text-[clamp(1.9rem,4.2vw,4.8rem)] [font-family:'Glacial_Indifference',sans-serif]"
        >
          Denmark High School AP Ambassadors
        </h1>
        <p
          class="mt-2 max-w-3xl italic text-white/90 text-[clamp(1rem,1.7vw,2.15rem)] [font-family:'Glacial_Indifference',sans-serif]"
        >
          In Pursuit of Excellence
        </p>
      </div>
    </div>
  </div>
</section>
