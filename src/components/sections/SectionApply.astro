---
const qualifications = [
  "Students must have been or are currently enrolled in an Advanced Placement (AP) class.",
  "Students must be comfortable speaking in front of and leading large audiences of their peers, parents, and educators.",
  "Students must be willing to represent their school and promote AP programs at Denmark HS and beyond.",
  "Students must have been nominated by AP teachers from years prior.",
];

const selection = [
  "Students are nominated by AP teachers.",
  "Students receive notification of their nomination along with nominee session details.",
  "Students attend the nominee information session (Dane Time session).",
  "Students complete the application and turn it in to Mrs. Schneider / Mrs. Hartshorn by the date shared at the nominee session.",
  "Potential screening interview.",
  "Everyone who applied will be notified through school Outlook email when results are available.",
];

const responsibilities = [
  "Attend AP Ambassador weekly meetings (Dane Time).",
  "Recruit and promote AP course registration.",
  "Host and support AP events (AP Night, Pathway Night, etc).",
  "Support new-student sessions and school tours.",
  "Goal setting with AP students.",
  "AP Recognition & Celebration.",
  "AP Campaigns.",
  "Lead inside and outside the classroom.",
];

/** Legal pad: horizontal rule rhythm (wider spacing). */
const padRuleStep = "3.25rem";
---

<section
  id="apply"
  class="border-t border-slate-200/90 bg-white py-24 sm:py-28"
  aria-labelledby="apply-heading"
>
  <div class="page-shell">
    <div class="max-w-4xl">
      <p class="text-xs font-bold font-label uppercase tracking-[0.2em] text-sea">Apply</p>
      <h2 id="apply-heading" class="mt-3 text-3xl font-semibold text-ink md:text-4xl lg:text-5xl">
        Transformative Opportunities Lie Ahead
      </h2>
    </div>

    <div
      class="mt-10 grid gap-6 lg:grid-cols-2 lg:items-stretch lg:gap-8"
    >
      <div class="flex min-h-0 flex-col gap-6">
        <!-- Top-left + bottom-right rounded only (other corners sharp) -->
        <article
          class="rounded-bl-none rounded-br-[2rem] rounded-tl-[2rem] rounded-tr-none bg-[#94bbff] p-6 md:p-8"
        >
          <h3 class="text-3xl font-medium uppercase tracking-[0.08em] text-black md:text-4xl">
            Application Link
          </h3>
          <p class="mt-4 text-base font-medium leading-relaxed text-black md:text-lg">
            2025-2026 applications are shared at the nominee meeting. Contact
            <a
              class="font-bold text-black underline decoration-black underline-offset-2 hover:opacity-80"
              href="mailto:tschneider@forsyth.k12.ga.us"
            >
              tschneider@forsyth.k12.ga.us
            </a>
            for details. Complete only if nominated. No late applications.
          </p>
        </article>

        <article
          class="rounded-bl-none rounded-br-[2rem] rounded-tl-[2rem] rounded-tr-none bg-[#f0f2f8] p-6 md:p-8"
        >
          <h3 class="text-3xl font-medium uppercase tracking-[0.08em] text-black md:text-4xl">
            Qualifications
          </h3>
          <ul class="mt-6 flex flex-col gap-5 md:gap-6">
            {
              qualifications.map((item) => (
                <li class="flex gap-4">
                  <span
                    class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-full bg-black text-white"
                    aria-hidden="true"
                  >
                    <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path
                        d="M2.5 7.2 5.5 10 11.5 4"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      ></path>
                    </svg>
                  </span>
                  <p class="text-base font-medium leading-relaxed text-black md:text-lg">
                    {item}
                  </p>
                </li>
              ))
            }
          </ul>
        </article>
      </div>

      <article
        class="relative mt-6 flex min-h-0 flex-col overflow-hidden border border-[#c9a227]/50 bg-[#fff9dc] shadow-sm lg:mt-0 lg:h-full"
      >
        <!-- Double margin: slightly thicker than 1px rules (~2px) -->
        <div
          class="pointer-events-none absolute inset-y-0 left-10 z-0 w-[2px] bg-[#d98324] sm:left-11"
          aria-hidden="true"
        ></div>
        <div
          class="pointer-events-none absolute inset-y-0 left-[calc(2.5rem+5px)] z-0 w-[2px] bg-[#d98324] sm:left-[calc(2.75rem+5px)]"
          aria-hidden="true"
        ></div>

        <div class="relative z-10 flex min-h-0 flex-1 flex-col px-5 pb-10 pt-12 md:px-8 md:pb-12 md:pt-14">
          <h3
            class="text-center text-2xl font-medium uppercase tracking-[0.18em] text-black sm:text-3xl md:text-4xl"
          >
            Responsibilities
          </h3>

          <!-- Horizontal rules: list area only; rules run to bottom of pad for a full sheet look -->
          <div class="relative -mx-5 mt-10 min-h-0 flex-1 md:-mx-8">
            <div
              class="pointer-events-none absolute inset-0 z-0"
              style={`background-image: repeating-linear-gradient(to bottom, transparent 0, transparent calc(${padRuleStep} - 1px), rgba(120, 165, 215, 0.48) calc(${padRuleStep} - 1px), rgba(120, 165, 215, 0.48) ${padRuleStep});`}
              aria-hidden="true"
            ></div>
            <div class="relative z-10 px-5 pb-1 pl-[4.25rem] pr-2 sm:pl-[4.75rem] md:px-8 md:pl-[5rem] lg:min-h-0">
              <ul class="flex flex-col">
                {
                  responsibilities.map((item) => (
                    <li class="flex min-h-[3.25rem] items-end pb-0.5 pt-0 text-lg font-medium leading-snug text-black md:text-xl">
                      {item}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </article>
    </div>

    <article
      class="mt-6 rounded-2xl border border-slate-200/90 bg-white p-6 shadow-sm md:p-8"
    >
      <h3 class="text-3xl font-normal uppercase tracking-[0.08em] text-black md:text-4xl">
        Selection Process
      </h3>

      <!-- Desktop: one column per step; segment caps square at column joins so lines read continuous -->
      <ol class="mt-8 hidden list-none grid-cols-6 gap-x-0 p-0 md:grid">
        {
          selection.map((step, i) => {
            const isFirst = i === 0;
            const isLast = i === selection.length - 1;
            const leftSegRound =
              `h-1.5 min-h-[6px] min-w-0 flex-1 bg-black rounded-r-full ${isFirst ? "rounded-l-full" : "rounded-l-none"}`;
            const rightSegRound =
              `h-1.5 min-h-[6px] min-w-0 flex-1 bg-black rounded-l-full ${isLast ? "rounded-r-full" : "rounded-r-none"}`;
            return (
              <li class="flex min-w-0 flex-col items-center">
                <div class="flex h-14 w-full min-w-0 items-center gap-4 px-0">
                  <div class={leftSegRound} aria-hidden="true"></div>
                  <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full border-[4px] border-black bg-white text-sm font-medium text-black">
                    {i + 1}
                  </span>
                  <div class={rightSegRound} aria-hidden="true"></div>
                </div>
                <p class="mt-7 w-full px-1 text-center text-sm font-normal leading-snug text-black">
                  <span class="sr-only">Step {i + 1}: </span>
                  {step}
                </p>
              </li>
            );
          })
        }
      </ol>

      <!-- Mobile: outline nodes, thicker stroke, space between spine and circle -->
      <ol class="mt-8 list-none space-y-0 p-0 md:hidden">
        {
          selection.map((step, i) => (
            <li class="flex gap-4">
              <div class="flex w-12 shrink-0 flex-col items-center">
                {i > 0 ? (
                  <div
                    class="mb-2 w-1.5 flex-1 shrink-0 rounded-full bg-black"
                    style="min-height: 0.75rem;"
                    aria-hidden="true"
                  />
                ) : (
                  <div class="h-1 shrink-0" aria-hidden="true"></div>
                )}
                <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full border-[4px] border-black bg-white text-xs font-medium text-black">
                  {i + 1}
                </span>
                {i < selection.length - 1 ? (
                  <div
                    class="mt-2 w-1.5 flex-1 shrink-0 rounded-full bg-black"
                    style="min-height: 0.75rem;"
                    aria-hidden="true"
                  />
                ) : (
                  <div class="h-1 shrink-0" aria-hidden="true"></div>
                )}
              </div>
              <p class="pb-6 pt-1 text-sm font-normal leading-relaxed text-black">
                <span class="sr-only">Step {i + 1}: </span>
                {step}
              </p>
            </li>
          ))
        }
      </ol>
    </article>

  </div>
</section>
