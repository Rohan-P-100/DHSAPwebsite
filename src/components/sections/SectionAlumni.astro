---

<section
  id="alumni"
  class="border-t border-slate-200/90 bg-white py-24 sm:py-28"
  aria-labelledby="alumni-heading"
>
  <div class="page-shell">
    <div class="max-w-4xl">
      <p class="text-xs font-bold font-label uppercase tracking-[0.2em] text-sea">Alumni</p>
      <h2 id="alumni-heading" class="mt-3 text-3xl font-semibold text-ink md:text-4xl lg:text-5xl">
        Once A Leader, Always A Leader
      </h2>
    </div>

    <div class="mt-10 flex justify-center">
      <div class="inline-flex rounded-full border border-slate-200 bg-white p-1">
        <button
          type="button"
          data-year-btn="2024"
          class="alumni-toggle rounded-full px-12 py-2 text-3xl font-medium text-ink transition-colors"
          aria-controls="alumni-panel-2024"
          aria-expanded="true"
        >
          2024
        </button>
        <button
          type="button"
          data-year-btn="2025"
          class="alumni-toggle rounded-full px-12 py-2 text-3xl font-medium text-ink transition-colors"
          aria-controls="alumni-panel-2025"
          aria-expanded="false"
        >
          2025
        </button>
      </div>
    </div>

    <div id="alumni-panel-2024" data-year-panel="2024" class="mt-10">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {alumniCards["2024"].map((card) => (
          <article class="overflow-hidden rounded-[1.5rem] bg-[#dfe2eb] text-center">
            <div class="relative aspect-[5/4] overflow-hidden rounded-t-[1.5rem] bg-gradient-to-b from-[#abd7f1] to-[#e7f2f8]">
              <img
                src={card.imageSrc}
                alt={card.imageAlt}
                class="h-full w-full object-cover object-top"
                loading="lazy"
              />
            </div>
            <div class="px-4 py-6">
              <h3 class="text-[1.65rem] font-semibold leading-tight text-black">{card.name}</h3>
              <p class="mt-2 text-[1.25rem] leading-tight text-black/90">{card.college}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div id="alumni-panel-2025" data-year-panel="2025" class="mt-10 hidden">
      <div class="rounded-2xl border border-slate-200 bg-[#f3f6fb] px-6 py-10 text-center">
        <p class="text-xl font-semibold text-ink md:text-2xl">Class of 2025 alumni profiles are in progress.</p>
        <p class="mt-2 text-base text-ink/75 md:text-lg">
          We are currently collecting names, college commitments, and photos.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll("[data-year-btn]");
  const panels = document.querySelectorAll("[data-year-panel]");

  function setYear(year) {
    panels.forEach((panel) => {
      const show = panel.getAttribute("data-year-panel") === year;
      panel.classList.toggle("hidden", !show);
    });

    buttons.forEach((button) => {
      const selected = button.getAttribute("data-year-btn") === year;
      button.setAttribute("aria-expanded", selected ? "true" : "false");
      button.classList.toggle("bg-[#f3f6fb]", selected);
    });
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const year = button.getAttribute("data-year-btn");
      if (year) setYear(year);
    });
  });

  setYear("2024");
</script>
