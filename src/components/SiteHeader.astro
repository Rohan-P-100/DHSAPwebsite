---
const navCenter = [
  { href: "/#about", label: "About" },
  { href: "/#impact", label: "Our Impact" },
  { href: "/#events", label: "In Action" },
  { href: "/#alumni", label: "Alumni" },
];
---

<header id="site-header" class="sticky top-0 z-50 bg-white">
  <div class="relative mx-auto h-16 w-full max-w-[132rem] px-3 sm:h-20 sm:px-6 lg:h-24 lg:px-10">
    <div class="flex h-full items-center justify-between">
      <nav class="hidden items-center gap-8 md:flex lg:gap-10" aria-label="Primary">
        {
          navCenter.map((item) => (
            <a
              href={item.href}
              class="whitespace-nowrap text-sm font-bold text-black transition-colors hover:text-ink/75"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <button
        type="button"
        id="nav-toggle"
        class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white p-2.5 text-ink md:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open menu"
      >
        <span class="sr-only">Toggle navigation</span>
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          class="open-icon"
        >
          <path d="M5 7h14M5 12h14M5 17h14"></path>
        </svg>
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          class="close-icon hidden"
        >
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>

      <div id="center-logo-wrap" class="absolute left-1/2 top-full -translate-x-1/2 -translate-y-1/2">
        <a
          href="/"
          class="group block rounded-full focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-ink"
          aria-label="Go to top"
        >
          <span class="grid h-28 w-28 place-items-center overflow-hidden rounded-full bg-white sm:h-36 sm:w-36 lg:h-44 lg:w-44">
            <img
              src="/images/logo.png"
              alt="Denmark High School AP Ambassadors"
              class="h-[84%] w-[84%] object-contain"
            />
          </span>
        </a>
      </div>

      <div class="flex items-center gap-2 md:gap-3">
        <a
          href="/#apply"
          class="hidden items-center gap-1.5 rounded-full bg-ink px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-sea sm:inline-flex"
        >
          Apply
          <span aria-hidden="true" class="text-xs opacity-90">↗</span>
        </a>
        <a
          href="/#apply"
          class="inline-flex rounded-full bg-ink px-3 py-2 text-xs font-semibold text-white sm:hidden"
        >
          Apply
        </a>
      </div>
    </div>
  </div>

  <div id="mobile-nav" class="hidden bg-white px-4 py-3 md:hidden" hidden>
    <nav class="flex flex-col gap-0.5" aria-label="Mobile primary">
      {
        navCenter.map((item) => (
          <a
            href={item.href}
            class="rounded-xl px-3 py-3 text-base font-bold text-black transition-colors hover:bg-slate-50"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/#apply"
        class="mt-2 inline-flex items-center justify-center gap-1 rounded-full bg-ink px-4 py-3 text-center text-base font-semibold text-white"
      >
        Apply ↗
      </a>
    </nav>
  </div>
</header>

<style>
  #center-logo-wrap {
    transition: top 260ms ease, transform 260ms ease;
  }

  #site-header.is-past-hero #center-logo-wrap {
    top: 50%;
    transform: translate(-50%, -50%) scale(0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    #center-logo-wrap {
      transition: none;
    }
  }
</style>

<script>
  const siteHeader = document.getElementById("site-header");
  const heroSection = document.getElementById("top");
  const toggle = document.getElementById("nav-toggle");
  const panel = document.getElementById("mobile-nav");
  const openIcon = toggle?.querySelector(".open-icon");
  const closeIcon = toggle?.querySelector(".close-icon");

  function setOpen(open) {
    if (!toggle || !panel) return;
    panel.classList.toggle("hidden", !open);
    panel.hidden = !open;
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    openIcon?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
    document.body.classList.toggle("overflow-hidden", open);
  }

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    setOpen(!isOpen);
  });

  panel?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });

  function syncHeaderState() {
    if (!siteHeader || !heroSection) return;
    const heroBottom = heroSection.getBoundingClientRect().bottom;
    const headerHeight = siteHeader.getBoundingClientRect().height;
    siteHeader.classList.toggle("is-past-hero", heroBottom <= headerHeight + 10);
  }

  syncHeaderState();
  window.addEventListener("scroll", syncHeaderState, { passive: true });
  window.addEventListener("resize", syncHeaderState);
</script>
